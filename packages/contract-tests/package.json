{
  "name": "@company-intelligence/contract-tests",
  "version": "0.1.0",
  "description": "Reusable Company Intelligence contract test suite (validates the mock server and the private service).",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@company-intelligence/provider": "workspace:*",
    "@company-intelligence/types": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=2"
  },
  "devDependencies": {
    "@company-intelligence/client": "workspace:*",
    "@company-intelligence/mock-server": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
