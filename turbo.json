{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": {},
    "typecheck": { "outputs": ["*.tsbuildinfo"] },
    "test": { "outputs": ["coverage/**"] },
    "clean": { "cache": false }
  }
}
